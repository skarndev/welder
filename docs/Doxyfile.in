# Doxyfile for welder's C++ API reference (configured by docs/CMakeLists.txt).
#
# Reads the *real* headers under src/welder/ through welder's own INPUT_FILTER
# (tools/welder_doxygen_filter.py), so the [[=welder::doc/returns/tparam]]
# annotations become Doxygen comments. Output is themed with doxygen-awesome-css
# and lands in <site>/api/ next to the mkdocs guide.

PROJECT_NAME           = "welder"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Bindings for annotated C++ types, from C++26 reflection"
PROJECT_LOGO           = @WELDER_LOGO@

OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIR@
GENERATE_HTML          = YES
HTML_OUTPUT            = api
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# The symbol -> URL map consumed by the mkdocs apilink.py hook (which auto-links
# inline code spans in the guide to these reference pages). Lives next to api/,
# not inside it, so it is never published with the site.
GENERATE_TAGFILE       = @DOXYGEN_OUTPUT_DIR@/welder.tag

# --- Inputs: the whole library, internals included ---------------------------
INPUT                  = @WELDER_SRC@ \
                         @DOXYGEN_MAINPAGE@
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.md
USE_MDFILE_AS_MAINPAGE = @DOXYGEN_MAINPAGE@

# Read welder annotations via the INPUT_FILTER (needs a Python with `lark`).
INPUT_FILTER           = "@WELDER_FILTER_PYTHON@ @WELDER_FILTER@"

# --- What to extract: everything, including detail/ and templates ------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES
INTERNAL_DOCS          = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_HEADERFILE        = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# --- C++ / preprocessing -----------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
BUILTIN_STL_SUPPORT    = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = "__cpp_reflection=1"

# --- Diagnostics: internals are intentionally under-documented ---------------
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# --- Graphs (only when Graphviz is present) ----------------------------------
HAVE_DOT               = @DOXYGEN_HAVE_DOT@
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = NO
UML_LOOK               = YES

# --- Modern theme: doxygen-awesome-css (sidebar layout) ----------------------
# doxygen-awesome requires LIGHT here and supplies its own dark-mode toggle.
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
# doxygen-awesome themes all colors via CSS vars and asks that HUE/SAT stay at
# their defaults — custom values bake warm hardcoded colors into doxygen.css /
# navtree.css that don't adapt to dark mode. The spark accent is applied in
# doxygen-extra.css instead.
HTML_COLORSTYLE        = LIGHT
HTML_COPY_CLIPBOARD    = NO
HTML_HEADER            = @DOXYGEN_HTML_HEADER@
HTML_EXTRA_STYLESHEET  = @DOXYGEN_HTML_EXTRA_STYLESHEET@
HTML_EXTRA_FILES       = @DOXYGEN_HTML_EXTRA_FILES@
