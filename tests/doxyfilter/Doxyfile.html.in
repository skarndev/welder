# Doxyfile for the browsable HTML of the doxyfilter corpus (configured by
# tests/doxyfilter/CMakeLists.txt; built by the doxyfilter-html target).
PROJECT_NAME     = "welder doxyfilter corpus"
PROJECT_BRIEF    = "what Doxygen sees through tools/welder-doxygen-filter.py"
INPUT            = @CMAKE_CURRENT_SOURCE_DIR@/corpus.hpp
INPUT_FILTER     = "@WELDER_FILTER_PYTHON@ @_filter@"
EXTRACT_ALL      = YES
OUTPUT_DIRECTORY = @CMAKE_CURRENT_BINARY_DIR@
GENERATE_HTML    = YES
HTML_OUTPUT      = html
GENERATE_LATEX   = NO
GENERATE_XML     = NO
QUIET            = YES
WARN_IF_UNDOCUMENTED = NO
