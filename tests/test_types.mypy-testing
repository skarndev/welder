# Type-level tests for welder's generated stubs (pytest-mypy-testing cases).
#
# The behavioral specs (test_*.py) reach the extension through a runtime-selected
# ``mod: ModuleType`` fixture, so to mypy every access is ``Any`` — they verify
# *runtime* behavior. These cases are the complementary *type* check: each
# ``@pytest.mark.mypy_testing`` function is run through mypy by pytest-mypy-testing
# and the ``# R:`` comments assert the revealed types, so a wrong type in a
# generated stub fails the matching case.
#
# They are backend-agnostic: they import the canonical name ``welder_test``, which
# each backend's CTest puts on ``MYPYPATH`` (pointing at that backend's generated
# stub tree, exposed under this name). The functions are never executed — only
# mypy reads them — so ``welder_test`` need only exist as a stub.

import pytest


@pytest.mark.mypy_testing
def mypy_test_data_members_keep_their_cpp_types() -> None:
    import welder_test

    v = welder_test.Values()
    reveal_type(v.i)  # R: int
    reveal_type(v.d)  # R: float
    reveal_type(v.s)  # R: str


@pytest.mark.mypy_testing
def mypy_test_constructors_methods_and_statics() -> None:
    import welder_test

    reveal_type(welder_test.Counter().value())  # R: int
    reveal_type(welder_test.Counter(5).value())  # R: int
    reveal_type(welder_test.Counter.version())  # R: int


@pytest.mark.mypy_testing
def mypy_test_overloaded_method_return() -> None:
    import welder_test

    reveal_type(welder_test.Calc(10).sum(5))  # R: int
    reveal_type(welder_test.Calc(10).sum(5, 5))  # R: int


@pytest.mark.mypy_testing
def mypy_test_bound_namespace_is_a_typed_submodule() -> None:
    from welder_test import documented

    reveal_type(documented.add(1, 2))  # R: int
    reveal_type(documented.Circle(1.0).area())  # R: float
    reveal_type(documented.ANSWER)  # R: int
