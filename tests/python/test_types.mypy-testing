# Type-level tests for welder's generated stubs (pytest-mypy-testing cases).
#
# The behavioral specs (test_*.py) reach the extension through a runtime-selected
# ``mod: ModuleType`` fixture, so to mypy every access is ``Any`` — they verify
# *runtime* behavior. These cases are the complementary *type* check: each
# ``@pytest.mark.mypy_testing`` function is run through mypy by pytest-mypy-testing
# and the ``# R:`` comments assert the revealed types, so a wrong type in a
# generated stub fails the matching case.
#
# They are backend-agnostic: they import the canonical name ``welder_test``, which
# each backend's CTest puts on ``MYPYPATH`` (pointing at that backend's generated
# stub tree, exposed under this name). The functions are never executed — only
# mypy reads them — so ``welder_test`` need only exist as a stub.

import pytest


@pytest.mark.mypy_testing
def mypy_test_data_members_keep_their_cpp_types() -> None:
    from welder_test import resolution

    v = resolution.Values()
    reveal_type(v.i)  # R: int
    reveal_type(v.d)  # R: float
    reveal_type(v.s)  # R: str


@pytest.mark.mypy_testing
def mypy_test_constructors_methods_and_statics() -> None:
    from welder_test import methods

    reveal_type(methods.Counter().value())  # R: int
    reveal_type(methods.Counter(5).value())  # R: int
    reveal_type(methods.Counter.version())  # R: int


@pytest.mark.mypy_testing
def mypy_test_overloaded_method_return() -> None:
    from welder_test import methods

    reveal_type(methods.Calc(10).sum(5))  # R: int
    reveal_type(methods.Calc(10).sum(5, 5))  # R: int


@pytest.mark.mypy_testing
def mypy_test_bound_namespace_is_a_typed_submodule() -> None:
    from welder_test import documented

    reveal_type(documented.add(1, 2))  # R: int
    reveal_type(documented.Circle(1.0).area())  # R: float
    reveal_type(documented.ANSWER)  # R: int


# --- STL containers (C++ side: tests/common/cpp/stl.hpp) ---------------------
# A container PARAMETER types as the wide accepted input (a Sequence — so plain
# lists and tuples typecheck as arguments), while a RETURN types as the concrete
# native object the caster produces (list[T], dict[K, V], tuple[...], T | None).


@pytest.mark.mypy_testing
def mypy_test_vector_returns_are_lists_and_parameters_accept_lists() -> None:
    from welder_test import stl

    reveal_type(stl.iota(3))  # R: list[int]
    # a std::vector<int> parameter accepts a list — and any other sequence
    reveal_type(stl.total([1, 2, 3]))  # R: int
    reveal_type(stl.total((4, 5)))  # R: int


@pytest.mark.mypy_testing
def mypy_test_vector_of_welded_type_spells_the_bound_name() -> None:
    from welder_test import stl

    reveal_type(stl.wrap_all([7, 9]))  # R: list[welder_test.stl.Item]


@pytest.mark.mypy_testing
def mypy_test_map_returns_a_dict() -> None:
    from welder_test import stl

    reveal_type(stl.histogram(["a", "b", "a"]))  # R: dict[str, int]


@pytest.mark.mypy_testing
def mypy_test_optional_is_value_or_none() -> None:
    from welder_test import stl

    reveal_type(stl.find_positive([-1, 5]))  # R: int | None
    # a std::optional<int> parameter accepts None and a plain int
    reveal_type(stl.value_or(None, 8))  # R: int
    reveal_type(stl.value_or(3, 8))  # R: int


@pytest.mark.mypy_testing
def mypy_test_pair_returns_a_tuple() -> None:
    from welder_test import stl

    reveal_type(stl.labelled(5))  # R: tuple[int, str]


@pytest.mark.mypy_testing
def mypy_test_container_members_read_concrete_and_write_wide() -> None:
    from welder_test import stl

    b = stl.Basket()
    reveal_type(b.ints)  # R: list[int]
    reveal_type(b.ranks)  # R: dict[str, int]
    reveal_type(b.discount)  # R: float | None
    # the property setters accept the wide forms
    b.ints = [1, 2]
    b.ranks = {"gold": 1}
    b.discount = None


# --- opaque, reference-semantic containers (C++ side: opaque.hpp) -------------
# The counterpart to the by-value cases above: an opaque container member types as
# the BOUND WRAPPER class, not list[T]/dict[K, V]. That is the whole type-level
# tell that it binds by reference (a live IntVector, not a fresh list snapshot).


@pytest.mark.mypy_testing
def mypy_test_opaque_member_is_the_wrapper_not_a_list() -> None:
    from welder_test import opaque

    # a std::vector<float> member -> the bound FloatVector, NOT list[float]
    reveal_type(opaque.Signal().samples)  # R: welder_test.opaque.FloatVector
    reveal_type(opaque.sum_samples(opaque.Signal()))  # R: float
    # a no_reassign member types identically (read-only property, same wrapper)
    reveal_type(opaque.Signal().locked)  # R: welder_test.opaque.FloatVector
    # element access is typed by the wrapper's __getitem__
    reveal_type(opaque.FloatVector()[0])  # R: float
